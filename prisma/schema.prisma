// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ImportJob {
  id              String         @id @default(cuid())
  shop            String
  fileName        String
  fileType        String
  status          String         @default("PENDING")
  totalRows       Int            @default(0)
  processedRows   Int            @default(0)
  successCount    Int            @default(0)
  errorCount      Int            @default(0)
  bulkOperationId String?
  rolledBack      Boolean        @default(false)
  errors          ImportError[]
  actions         ImportAction[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([shop])
}

model ImportAction {
  id               String    @id @default(cuid())
  jobId            String
  collectionId     String
  collectionHandle String
  action           String    // "created" | "updated"
  previousData     String?   // JSON snapshot before update
  createdAt        DateTime  @default(now())
  job              ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model ImportError {
  id      String    @id @default(cuid())
  jobId   String
  row     Int
  field   String?
  message String
  rawData String?
  job     ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ScheduledImport {
  id                String    @id @default(cuid())
  shop              String
  scheduledAt       DateTime
  fileName          String
  fileData          Bytes
  fileType          String
  duplicateStrategy String    @default("skip")
  status            String    @default("PENDING")
  recurrence        String    @default("none") // none | daily | weekly | monthly
  nextRunAt         DateTime?
  jobId             String?
  createdAt         DateTime  @default(now())

  @@index([shop, scheduledAt])
  @@index([status, nextRunAt])
}

model NotificationSetting {
  id               String  @id @default(cuid())
  shop             String  @unique
  email            String?
  slackWebhookUrl  String?
  flowWebhookUrl   String?
  notifyOnComplete Boolean @default(true)
  notifyOnFail     Boolean @default(true)
}

model ShopPlan {
  id             String   @id @default(cuid())
  shop           String   @unique
  plan           String   @default("free") // free | pro | premium
  subscriptionId String?
  updatedAt      DateTime @updatedAt
}

model ImportWebhookKey {
  id        String   @id @default(cuid())
  shop      String   @unique
  keyHash   String   // SHA-256 of the raw key
  createdAt DateTime @default(now())
  lastUsed  DateTime?
}

model ImportTemplate {
  id          String   @id @default(cuid())
  shop        String
  name        String
  columnMap   String   // JSON: { userColumn: canonicalField }
  createdAt   DateTime @default(now())

  @@unique([shop, name])
  @@index([shop])
}
